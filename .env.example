# ACE Suite site — environment
#
# Copy to .env (gitignored) and fill in real values. NEVER put real secrets in
# this file — it is committed.

# ── Licence issuing (the site → gateway contract) ──────────────────────────────
# RS256 PRIVATE key (PKCS8 PEM), used by /api/license/issue to sign licence JWTs.
# The matching PUBLIC key goes to the gateway as LICENSE_PUBLIC_KEY. Generate:
#   openssl genrsa -out license.pem 2048
#   openssl pkcs8 -topk8 -nocrypt -in license.pem -out license-pkcs8.pem   # → this var
#   openssl rsa -in license.pem -pubout -out license-public.pem            # → gateway
# Paste the PKCS8 PEM (newlines preserved, or \n-escaped in one line).
LICENSE_PRIVATE_KEY=

# Dev override: when set, /api/license/issue returns a full Pro entitlement for
# this email (no Supabase needed) so the issuing + gateway contract can be tested
# end-to-end. Leave UNSET in production — real auth resolves entitlements from the
# user's session. See src/lib/entitlements.ts.
LICENSE_DEV_EMAIL=

# ── Supabase — ACE Account project ────────────────────────────────────────────
# Powers sign-in, session cookies, and entitlement resolution.
# Values: supabase.com → ACE Suite project → Settings → API.
# URL + anon key are public (shipped to the browser); the SERVICE_ROLE key is a
# full-access secret — server-only, never expose it.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe — consumer product billing (portal + checkout) ─────────────────────
# STRIPE_SECRET_KEY is server-only (used by /api/stripe/portal and consumer checkout)
STRIPE_SECRET_KEY=
# App URL for Stripe success/cancel/portal return URLs
NEXT_PUBLIC_APP_URL=https://www.ace-presenter.app

# ── Gateway admin — licence revocation on Stripe cancel ───────────────────────
ACE_GATEWAY_URL=https://api.ace-presenter.app
ACE_GATEWAY_ADMIN_SECRET=            # must match the gateway's ADMIN_SECRET

# ── Stripe — webhook signature verification ───────────────────────────────────
# Subscriptions must carry metadata.license_id (set at checkout) so the cancel
# webhook can revoke the right licence. From Stripe → Developers → Webhooks.
STRIPE_WEBHOOK_SECRET=
